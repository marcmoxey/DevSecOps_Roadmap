#!/bin/bash

#!/bin/bash

# 1. Get current disk usage as a number
usage=$(df -h / | awk 'NR==2 {print $5}' | tr -d '%')

# 2. Compare against threshold (80%)
if [ "$usage" -gt 80 ]; then
    # 3. Log a WARNING if over threshold
    echo "$(date): WARNING - Disk usage at ${usage}%" >> ~/disk-check.log
else
    # 4. Log OK if under threshold
    echo "$(date): OK - Disk usage at ${usage}%" >> ~/disk-check.log
fi  
